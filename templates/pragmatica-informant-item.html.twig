{% import '@pragmatica/pragmatica-macros.html.twig' as macros %}

<div class="prag-page-header">
  <div class="prag-page-header-icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
      <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
    </svg>
  </div>
  <div class="prag-page-header-body">
    <p class="prag-page-header-eyebrow">{{ 'Informante'|t }}</p>
    <h1 class="prag-page-header-title">{{ informant.label }}</h1>
    {% if informant._attributes %}
      <div class="prag-informant-attrs">
        {% for attr_label, attr_value in informant._attributes %}
          <div class="prag-informant-attr">
            <span class="prag-informant-attr-label">{{ attr_label }}</span>
            <span class="prag-informant-attr-value">{{ attr_value }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<div class="prag-section-divider">{{ 'Respostas do informante'|t }}</div>
<div class="d-flex flex-column gap-3 mt-3">
  {% if responses %}
    {% for response in responses %}
      {{ macros.response_card(response.label, response.url, response.situation, null, response.labels) }}
    {% endfor %}
  {% else %}
    <p>{{ 'Informante não respondeu a nenhuma situação'|t }}</p>
  {% endif %}
</div>
