{% import '@pragmatica/pragmatica-macros.html.twig' as macros %}

<h1 class="fs-3 my-3">{{ 'Busca'|t }}</h1>

{# ── Filter toggle — plain heading row ───────────────────────────── #}
<button
  class="pragmatica-filter-toggle"
  type="button"
  data-bs-toggle="collapse"
  data-bs-target="#pragmatica-filters-panel"
  aria-expanded="false"
  aria-controls="pragmatica-filters-panel"
>
  <span class="pragmatica-filter-toggle-label">
    {{ 'Filtros'|t }}
    {% if active_filters is not empty %}
      <span class="pragmatica-filter-count">{{ active_filters|length }}</span>
    {% endif %}
  </span>
  <svg class="pragmatica-filter-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
    <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
  </svg>
</button>

{# Active filters summary — always visible #}
{% if active_filters is not empty %}
  <div class="pragmatica-active-filters d-flex flex-wrap gap-2 align-items-baseline mb-2 mt-2">
    {% for filter in active_filters %}
      <span class="pragmatica-active-filter-group">
        <span class="pragmatica-active-filter-label">{{ filter.label }}:</span>
        {% for val in filter.values %}
          <span class="badge rounded-pill pragmatica-active-filter-chip">{{ val }}</span>
        {% endfor %}
      </span>
    {% endfor %}
    <a href="{{ path('pragmatica.public.search') }}" class="btn btn-link btn-sm p-0 ms-1 text-danger">{{ 'Limpar filtros'|t }}</a>
  </div>
{% endif %}

{# Collapsible form — closed by default #}
<div class="collapse" id="pragmatica-filters-panel">
  <form method="GET" id="pragmatica-search-form" class="mb-4">
    <div class="accordion accordion-flush" id="pragmatica-filter-accordion">
      {% for group_key, group in filter_groups %}
        {% if group.fields is not empty %}
          <div class="accordion-item pragmatica-filter-group">
            <h3 class="accordion-header m-0">
              <button
                class="accordion-button pragmatica-filter-group-header"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#filter-group-{{ group_key }}"
                aria-expanded="true"
                aria-controls="filter-group-{{ group_key }}"
              >
                {{ group.label }}
              </button>
            </h3>
            <div id="filter-group-{{ group_key }}" class="accordion-collapse collapse show">
              <div class="accordion-body p-3">
                <div class="row g-3">
                  {% for field in group.fields %}
                    <div class="{{ group_key == 'situacao' ? 'col-12' : 'col-12 col-md-6 col-lg-4' }}">
                      {{ macros.renderField(field) }}
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="mt-3">
      <button type="submit" class="btn btn-primary">{{ 'Buscar'|t }}</button>
    </div>
  </form>
</div>

{# ── Results ───────────────────────────────────────────────────────── #}
<div>
  <h2 class="pragmatica-subtitle mt-4">
  {{ pager.total }} {{ pager.total == 1 ? 'resultado encontrado'|t : 'resultados encontrados'|t }}
  </h2>
  {% if results.responses %}

    {{ macros.pager(pager, 'pragmatica-search-form', 'pragmatica-page-select') }}
  
    {% for response in results.responses %}
      {{ macros.response_card(response.label, response.url, response.situation, response.informant, response.labels) }}
    {% endfor %}

    {{ macros.pager(pager, 'pragmatica-search-form', 'pragmatica-page-select') }}
  {% else %}
    <p>{{ 'Nenhum resultado encontrado.'|t }}</p>
  {% endif %}
</div>

