<div class="pragmatica">
  <h1 class="pragmatica-title">{{ 'Fontes'|t }}</h1>
  {% if sources %}
    <ul class="pragmatica-list">
      {% for source in sources %}
        <li class="pragmatica-list-item pragmatica-card">
          <div class="pragmatica-card-header">
            <a href="{{ path('pragmatica.source_public_item', {'pragmatica_source': source.id.value}) }}" class="pragmatica-card-title pragmatica-link">
              {{ source.name.value }}
            </a>
            <div class="pragmatica-tag">{{ source.type_id.entity.label }}</div>
          </div>
          <div class="pragmatica-card-content">
            {% if source.description.value %}
              <p class="pragmatica-card-description">{{ source.description.value }}</p>
            {% endif %}
            {% if source.plain_text.value %}
              <p class="pragmatica-excerpt">
                {{ source.plain_text.value|striptags|slice(0, 300) }}...
              </p>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="pragmatica-no-results">{{ 'Não há fontes cadastradas'|t }}</p>
  {% endif %}
</div>
